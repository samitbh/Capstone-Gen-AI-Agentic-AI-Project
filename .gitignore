# ====================================================================
# PROJECT EXCLUSION RULES
# ====================================================================

# Ignore the virtual environment folder to prevent uploading thousands of package files
venv/
ENV/

# Ignore local environment files to protect your Gemini and API keys from leaking online
.env
.env.*

# Ignore automatically generated Python cache folders to keep your commits clean
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Ignore local vector database records so you do not push dummy database states to GitHub
data/chroma_db/
*.db

# Ignore local test result screenshots to prevent uploading large image files and cluttering the repository
assets/screenshots/*

# Ignore raw data ingestion test assets to keep the code repository light
data/static_data/

# Ignore hidden operating system files generated by macOS and Windows
.DS_Store
Thumbs.db
